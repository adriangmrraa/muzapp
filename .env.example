# ============================================
# Mrs Muzzarella - Variables de Entorno
# ============================================
# Copiá este archivo como .env.local para desarrollo
# En Render: agregá estas variables en Environment

# --- FASE 1: Landing (MVP) ---
# ✅ = ya configurada en Render
# ⏳ = pendiente, se agrega cuando se implemente la fase

# ✅ Node
NODE_VERSION=20
NODE_ENV=production
NPM_CONFIG_PRODUCTION=false

# --- FASE 2: Database + Auth ---
# ✅ Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxx.sa-east-1.aws.neon.tech/muzapp?sslmode=require

# ⏳ Auth (NextAuth v5) — usar AUTH_SECRET / AUTH_URL (v5 convention)
AUTH_SECRET=tu-secret-generado-con-openssl-rand-base64-32
AUTH_URL=https://muzzarella.onrender.com
# NEXTAUTH_SECRET y NEXTAUTH_URL son aliases de las anteriores (v4 compat, no necesarios)

# --- FASE 3: Admin Panel ---
# (usa las mismas variables de Fase 2, no agrega nuevas)

# --- FASE 4: WhatsApp Agent ---
# ⏳ YCloud (proveedor WhatsApp)
YCLOUD_API_KEY=tu-api-key-de-ycloud
YCLOUD_WEBHOOK_SECRET=tu-webhook-secret-de-ycloud
WHATSAPP_PHONE_NUMBER=5491112345678

# ⏳ AI (OpenAI para el agente)
OPENAI_API_KEY=sk-tu-openai-api-key

# --- FASE 5: Atribución ---
# ⏳ Meta Ads (para enriquecer leads con nombres de creativos)
META_APP_ID=tu-meta-app-id
META_APP_SECRET=tu-meta-app-secret
